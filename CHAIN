titleBar.TextSize = 14
titleBar.TextXAlignment = Enum.TextXAlignment.Center
titleBar.Parent = mainFrame

-- Variabel drag
local dragging = false
local dragStartPos = nil
local frameStartPos = nil

titleBar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStartPos = input.Position
		frameStartPos = mainFrame.Position
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local delta = input.Position - dragStartPos
		local newX = frameStartPos.X.Offset + delta.X
		local newY = frameStartPos.Y.Offset + delta.Y
		mainFrame.Position = UDim2.new(frameStartPos.X.Scale, newX, frameStartPos.Y.Scale, newY)
	end
end)

-- Fungsi membuat tombol di dalam mainFrame
local function createButton(text, yPos)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(0, 230, 0, 34)
	btn.Position = UDim2.new(0, 15, 0, yPos)
	btn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
	btn.TextColor3 = Color3.new(1, 1, 1)
	btn.Font = Enum.Font.GothamBold
	btn.TextSize = 14
	btn.BorderSizePixel = 0
	btn.Text = text
	btn.AutoButtonColor = true
	btn.Parent = mainFrame
	return btn
end

local skillBtn = createButton("Skill Loop : OFF", 40)
local tpBtn = createButton("Auto TP (Smart) : OFF", 80)

skillBtn.MouseButton1Click:Connect(function()
	skillLoopEnabled = not skillLoopEnabled
	skillBtn.Text = "Skill Loop : " .. (skillLoopEnabled and "ON" or "OFF")
	if skillLoopEnabled then skillLoop() end
end)

tpBtn.MouseButton1Click:Connect(function()
	tpLoopEnabled = not tpLoopEnabled
	tpBtn.Text = "Auto TP (Smart) : " .. (tpLoopEnabled and "ON" or "OFF")
	if tpLoopEnabled then tpEnemyLoop() end
end)
